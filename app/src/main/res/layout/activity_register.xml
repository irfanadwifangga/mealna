<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/white"
    tools:context=".RegisterActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/logo"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:src="@drawable/mealna_logo_header"
                android:contentDescription="@string/desc_logo"
                android:layout_marginTop="50dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/judul_daftar"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/primary_green"
                android:layout_marginTop="48dp"
                android:drawableStart="@drawable/ic_person_circle"
                android:drawablePadding="8dp"
                app:layout_constraintTop_toBottomOf="@+id/logo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/labelEmail"
                style="@style/LabelRegister"
                android:text="@string/hint_email"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@+id/title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <EditText
                android:id="@+id/emailInput"
                style="@style/Widget.Mealna.Input"
                android:hint="@string/hint_email_field"
                android:inputType="textEmailAddress"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@+id/labelEmail"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/labelPass"
                style="@style/LabelRegister"
                android:text="@string/hint_password"
                app:layout_constraintTop_toBottomOf="@+id/emailInput"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <EditText
                android:id="@+id/passwordInput"
                style="@style/Widget.Mealna.Input"
                android:hint="@string/hint_password_field"
                android:inputType="textPassword"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@+id/labelPass"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/labelConfirmPass"
                style="@style/LabelRegister"
                android:text="@string/hint_konfirmasi_password"
                app:layout_constraintTop_toBottomOf="@+id/passwordInput"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <EditText
                android:id="@+id/confirmPasswordInput"
                style="@style/Widget.Mealna.Input"
                android:hint="@string/hint_password_field"
                android:inputType="textPassword"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@+id/labelConfirmPass"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <LinearLayout
                android:id="@+id/loginLinkLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@+id/confirmPasswordInput"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sudah_punya_akun"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/loginLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/link_masuk"
                    android:textColor="@color/primary_green"
                    android:textStyle="bold"/>
            </LinearLayout>

            <Button
                android:id="@+id/registerButton"
                style="@style/Widget.Mealna.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/tombol_daftar"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="50dp"
                app:layout_constraintTop_toBottomOf="@+id/loginLinkLayout"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>