<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    tools:context=".SettingsActivity">

    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#9CCC65"
        app:layout_constraintTop_toTopOf="parent"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:paddingTop="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/judul_pengaturan_umum"
                android:backgroundTint="@color/white"
                android:textColor="@color/black"
                android:paddingVertical="12dp"
                android:layout_marginBottom="24dp"
                android:elevation="4dp"
                android:stateListAnimator="@null"/>

            <LinearLayout
                android:id="@+id/bahasaContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:background="@drawable/rounded_green_top_corners">

                <TextView
                    android:id="@+id/bahasaHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pengaturan_bahasa"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:padding="16dp"
                    android:background="@color/primary_green"
                    android:drawableEnd="@drawable/ic_arrow_up"/>

                <LinearLayout
                    android:id="@+id/bahasaDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="16dp"
                    android:background="@color/white"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/bahasa_indonesia"
                        style="@style/SettingsDropdownItem"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/bahasa_inggris"
                        style="@style/SettingsDropdownItem"/>

                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/faqContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"
                android:background="@drawable/rounded_green_top_corners">

                <TextView
                    android:id="@+id/faqHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/judul_faq"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:padding="16dp"
                    android:background="@color/primary_green"
                    android:drawableEnd="@drawable/ic_arrow_up"/>

                <TextView
                    android:id="@+id/faqContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/konten_faq"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:padding="16dp"
                    android:background="@color/white"
                    android:visibility="visible"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>