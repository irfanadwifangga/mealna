<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.Mealna.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/primary_green</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Mealna.Input" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/rounded_input_background</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="LabelRegister">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:layout_marginTop">16dp</item>
    </style>
    <style name="SettingsDropdownItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/rounded_input_background</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name:layout_marginBottom="8dp"/>
    </style>

</resources>